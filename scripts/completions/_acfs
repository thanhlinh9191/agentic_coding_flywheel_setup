#compdef acfs
# Zsh completion for ACFS (Agentic Coding Flywheel Setup)
# Install: Copy to a directory in $fpath (e.g., ~/.zsh/completions/)
#          Then run: autoload -Uz compinit && compinit
#
# Related: bead bd-zhdi

_acfs() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '1: :_acfs_commands' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                newproj|new)
                    _arguments \
                        '-i[Launch TUI wizard for guided project setup]' \
                        '--interactive[Launch TUI wizard for guided project setup]' \
                        '--no-br[Skip beads (br) initialization]' \
                        '--no-claude[Skip Claude settings creation]' \
                        '--no-agents[Skip AGENTS.md template creation]' \
                        '-h[Show help message]' \
                        '--help[Show help message]'
                    ;;
                doctor|check)
                    _arguments \
                        '--json[Output results as JSON]' \
                        '--deep[Run functional tests (auth, connections)]' \
                        '--no-cache[Skip cache, run all checks fresh]' \
                        '--fix[Automatically apply safe fixes for failed checks]' \
                        '--dry-run[Preview fixes without applying (use with --fix)]' \
                        '-h[Show help message]' \
                        '--help[Show help message]'
                    ;;
                status)
                    _arguments \
                        '--json[Machine-readable JSON output]' \
                        '--short[Minimal output for shell prompt integration]' \
                        '--check-updates[Include network-based update checks]' \
                        '-h[Show help message]' \
                        '--help[Show help message]'
                    ;;
                info|i)
                    _arguments \
                        '--json[JSON output for scripting]' \
                        '--html[Self-contained HTML dashboard]' \
                        '--minimal[Just the essentials]'
                    ;;
                capacity|cap)
                    _arguments \
                        '--json[JSON output for scripting]' \
                        '--workload[Workload model]:workload:(light standard heavy)' \
                        '--profile[Target agent count]:agents:' \
                        '--recommend-ntm[Include NTM launch profile]' \
                        '-h[Show help message]' \
                        '--help[Show help message]'
                    ;;
                policy-lint|policy_lint)
                    _arguments \
                        '--json[JSON output]' \
                        '--human[Human-readable output]' \
                        '--root[Repository/root directory to scan]:directory:_files -/' \
                        '--file[Scan one file]:file:_files' \
                        '-h[Show help message]' \
                        '--help[Show help message]'
                    ;;
                credential-preflight|credential_preflight|secrets-preflight|secrets_preflight)
                    _arguments \
                        '--json[JSON output]' \
                        '--human[Human-readable output]' \
                        '--home[Target user home]:directory:_files -/' \
                        '--acfs-home[ACFS home]:directory:_files -/' \
                        '--root[Repository/root directory for relative paths]:directory:_files -/' \
                        '--file[Scan one file]:file:_files' \
                        '--exclude[Skip a file or directory]:path:_files' \
                        '--max-bytes[Skip files larger than this]:bytes:' \
                        '-h[Show help message]' \
                        '--help[Show help message]'
                    ;;
                provisioning-packet|provider-packet)
                    _arguments \
                        '--json[Emit machine-readable validation JSON]' \
                        '--markdown[Emit human-readable validation output]' \
                        '--file[Provider provisioning packet JSON file]:file:_files' \
                        '--packet[Provider provisioning packet JSON file]:file:_files' \
                        '-h[Show help message]' \
                        '--help[Show help message]'
                    ;;
                offline-pack|artifact-pack)
                    _arguments \
                        '1: :((build\\:Build\\ verified\\ offline\\ artifact\\ pack))' \
                        '--json[Emit machine-readable JSON]' \
                        '--markdown[Emit human-readable output]' \
                        '--output[Output directory]:directory:_files -/' \
                        '--module[Manifest module id to include]:module id:' \
                        '--dry-run[Print resolved plan without writing files]' \
                        '--best-effort[Write diagnostic pack after download failures]' \
                        '--source-root[ACFS source root]:directory:_files -/' \
                        '--manifest-file[Manifest YAML file]:file:_files' \
                        '--checksums-file[checksums.yaml file]:file:_files' \
                        '--arch[Target architecture]:architecture:(x86_64 aarch64)' \
                        '--ubuntu-version[Target Ubuntu version]:version:' \
                        '--timeout[Per-download timeout in seconds]:seconds:' \
                        '--expires-days[Pack expiry window in days]:days:' \
                        '-h[Show help message]' \
                        '--help[Show help message]'
                    ;;
                swarm)
                    _arguments -C \
                        '1: :_acfs_swarm_commands' \
                        '*::arg:->swarm_args'

                    case $state in
                        swarm_args)
                            case $line[1] in
                                plan|advisor)
                                    _arguments \
                                        '--json[JSON output]' \
                                        '--agents[Requested agent count]:agents:' \
                                        '--profile[Launch mix profile]:profile:(balanced codex-heavy review-heavy docs-heavy)' \
                                        '--workload[Workload model]:workload:(light standard heavy)' \
                                        '--status-file[Read an existing swarm status snapshot]:file:_files' \
                                        '-h[Show help message]' \
                                        '--help[Show help message]'
                                    ;;
                                status|snapshot)
                                    _arguments \
                                        '--json[JSON output]' \
                                        '-h[Show help message]' \
                                        '--help[Show help message]'
                                    ;;
                                doctor|preflight)
                                    _arguments \
                                        '--json[JSON output]' \
                                        '--status-file[Read an existing swarm status snapshot]:file:_files' \
                                        '-h[Show help message]' \
                                        '--help[Show help message]'
                                    ;;
                                simulate)
                                    _arguments \
                                        '--json[JSON output]' \
                                        '--counts[Comma-separated agent counts]:counts:' \
                                        '--workload[Workload model]:workload:(light standard heavy)' \
                                        '--artifact-dir[Directory for simulation artifacts]:directory:_files -/' \
                                        '--status-file[Read an existing swarm status snapshot]:file:_files' \
                                        '-h[Show help message]' \
                                        '--help[Show help message]'
                                    ;;
                                packet)
                                    _arguments \
                                        '--json[JSON output]' \
                                        '--markdown[Markdown output]' \
                                        '--bead[Beads issue ID]:bead:' \
                                        '--bead-id[Beads issue ID]:bead:' \
                                        '--bead-file[Read Beads JSON from fixture]:file:_files' \
                                        '--repo[Repository root]:directory:_files -/' \
                                        '--agent-name[Agent identity]:name:' \
                                        '--role[Agent role]:role:' \
                                        '--max-chars[Maximum packet characters]:chars:' \
                                        '--agents-file[AGENTS.md path]:file:_files' \
                                        '--readme-file[README.md path]:file:_files' \
                                        '--cm-file[CM context fixture]:file:_files' \
                                        '--cass-file[CASS context fixture]:file:_files' \
                                        '--no-live-context[Skip live cm and cass commands]' \
                                        '-h[Show help message]' \
                                        '--help[Show help message]'
                                    ;;
                                assign)
                                    _arguments \
                                        '--json[JSON output]' \
                                        '--markdown[Markdown output]' \
                                        '--agents[Requested agent count]:agents:' \
                                        '--roles[Role mix, e.g. implementation:2,review:1]:roles:' \
                                        '--profile[Role profile]:profile:(balanced codex-heavy review-heavy docs-heavy)' \
                                        '--ready-file[Read br ready JSON from file]:file:_files' \
                                        '--triage-file[Read bv robot triage JSON from file]:file:_files' \
                                        '-h[Show help message]' \
                                        '--help[Show help message]'
                                    ;;
                                convergence)
                                    _arguments \
                                        '--json[JSON output]' \
                                        '--markdown[Markdown output]' \
                                        '--epic[Epic Bead ID]:bead:' \
                                        '--epic-file[Read epic JSON from file]:file:_files' \
                                        '--issues-file[Read issue JSON/JSONL from file]:file:_files' \
                                        '--commits-file[Read commit evidence JSON from file]:file:_files' \
                                        '-h[Show help message]' \
                                        '--help[Show help message]'
                                    ;;
                                calibration)
                                    _arguments \
                                        '--json[JSON output]' \
                                        '--markdown[Markdown output]' \
                                        '--artifact-dir[Read simulation artifact directory]:directory:_files -/' \
                                        '--rch-file[Read optional RCH timing JSON]:file:_files' \
                                        '-h[Show help message]' \
                                        '--help[Show help message]'
                                    ;;
                                inventory|hosts|host-inventory)
                                    _arguments \
                                        '1:inventory command:(report import export validate)' \
                                        '--json[JSON output]' \
                                        '--markdown[Markdown output]' \
                                        '--inventory[Inventory file]:file:_files' \
                                        '--input[Input file for import]:file:_files' \
                                        '--output[Output file for import/export]:file:_files' \
                                        '--format[Export format]:format:(json)' \
                                        '--artifact-dir[Write error artifacts here]:directory:_files -/' \
                                        '-h[Show help message]' \
                                        '--help[Show help message]'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                swarm-plan|swarm_plan)
                    _arguments \
                        '--json[JSON output]' \
                        '--agents[Requested agent count]:agents:' \
                        '--profile[Launch mix profile]:profile:(balanced codex-heavy review-heavy docs-heavy)' \
                        '--workload[Workload model]:workload:(light standard heavy)' \
                        '--status-file[Read an existing swarm status snapshot]:file:_files' \
                        '-h[Show help message]' \
                        '--help[Show help message]'
                    ;;
                swarm-status|swarm_status)
                    _arguments \
                        '--json[JSON output]' \
                        '-h[Show help message]' \
                        '--help[Show help message]'
                    ;;
                swarm-simulate|swarm_simulate)
                    _arguments \
                        '--json[JSON output]' \
                        '--counts[Comma-separated agent counts]:counts:' \
                        '--workload[Workload model]:workload:(light standard heavy)' \
                        '--artifact-dir[Directory for simulation artifacts]:directory:_files -/' \
                        '--status-file[Read an existing swarm status snapshot]:file:_files' \
                        '-h[Show help message]' \
                        '--help[Show help message]'
                    ;;
                swarm-packet|swarm_packet)
                    _arguments \
                        '--json[JSON output]' \
                        '--markdown[Markdown output]' \
                        '--bead[Beads issue ID]:bead:' \
                        '--bead-id[Beads issue ID]:bead:' \
                        '--bead-file[Read Beads JSON from fixture]:file:_files' \
                        '--repo[Repository root]:directory:_files -/' \
                        '--agent-name[Agent identity]:name:' \
                        '--role[Agent role]:role:' \
                        '--max-chars[Maximum packet characters]:chars:' \
                        '--agents-file[AGENTS.md path]:file:_files' \
                        '--readme-file[README.md path]:file:_files' \
                        '--cm-file[CM context fixture]:file:_files' \
                        '--cass-file[CASS context fixture]:file:_files' \
                        '--no-live-context[Skip live cm and cass commands]' \
                        '-h[Show help message]' \
                        '--help[Show help message]'
                    ;;
                swarm-assign|swarm_assign)
                    _arguments \
                        '--json[JSON output]' \
                        '--markdown[Markdown output]' \
                        '--agents[Requested agent count]:agents:' \
                        '--roles[Role mix, e.g. implementation:2,review:1]:roles:' \
                        '--profile[Role profile]:profile:(balanced codex-heavy review-heavy docs-heavy)' \
                        '--ready-file[Read br ready JSON from file]:file:_files' \
                        '--triage-file[Read bv robot triage JSON from file]:file:_files' \
                        '-h[Show help message]' \
                        '--help[Show help message]'
                    ;;
                swarm-convergence|swarm_convergence)
                    _arguments \
                        '--json[JSON output]' \
                        '--markdown[Markdown output]' \
                        '--epic[Epic Bead ID]:bead:' \
                        '--epic-file[Read epic JSON from file]:file:_files' \
                        '--issues-file[Read issue JSON/JSONL from file]:file:_files' \
                        '--commits-file[Read commit evidence JSON from file]:file:_files' \
                        '-h[Show help message]' \
                        '--help[Show help message]'
                    ;;
                swarm-calibration|swarm_calibration)
                    _arguments \
                        '--json[JSON output]' \
                        '--markdown[Markdown output]' \
                        '--artifact-dir[Read simulation artifact directory]:directory:_files -/' \
                        '--rch-file[Read optional RCH timing JSON]:file:_files' \
                        '-h[Show help message]' \
                        '--help[Show help message]'
                    ;;
                swarm-inventory|swarm_inventory)
                    _arguments \
                        '1:inventory command:(report import export validate)' \
                        '--json[JSON output]' \
                        '--markdown[Markdown output]' \
                        '--inventory[Inventory file]:file:_files' \
                        '--input[Input file for import]:file:_files' \
                        '--output[Output file for import/export]:file:_files' \
                        '--format[Export format]:format:(json)' \
                        '--artifact-dir[Write error artifacts here]:directory:_files -/' \
                        '-h[Show help message]' \
                        '--help[Show help message]'
                    ;;
                coordinate|coord)
                    _arguments -C \
                        '1: :_acfs_coordinate_commands' \
                        '*::arg:->coordinate_args'

                    case $state in
                        coordinate_args)
                            case $line[1] in
                                doctor|preflight)
                                    _arguments \
                                        '--json[JSON output]' \
                                        '--status-file[Read an existing swarm status snapshot]:file:_files' \
                                        '-h[Show help message]' \
                                        '--help[Show help message]'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                cheatsheet|cs)
                    _arguments \
                        '--json[JSON output for scripting]'
                    ;;
                changelog|changes|log)
                    _arguments \
                        '--all[Show full changelog history]' \
                        '--since[Show changes since period]:period:' \
                        '--json[Output in JSON format]' \
                        '-h[Show help message]' \
                        '--help[Show help message]'
                    ;;
                export-config|export)
                    _arguments \
                        '--json[Output in JSON format]' \
                        '--minimal[Output only module list]' \
                        '--output[Write to file]:file:_files' \
                        '-h[Show help message]' \
                        '--help[Show help message]'
                    ;;
                session|sessions)
                    _arguments -C \
                        '1: :_acfs_session_commands' \
                        '*::arg:->session_args'

                    case $state in
                        session_args)
                            case $line[1] in
                                list)
                                    _arguments \
                                        '--json[JSON output]' \
                                        '--days[Filter by number of days]:days:' \
                                        '--agent[Filter by agent name]:agent:' \
                                        '--limit[Limit number of results]:limit:'
                                    ;;
                                export)
                                    _arguments \
                                        '1:session path:_files' \
                                        '--format[Output format]:format:(json markdown)' \
                                        '--no-sanitize[Do not sanitize output]' \
                                        '--output[Output file]:file:_files'
                                    ;;
                                recent)
                                    _arguments \
                                        '--workspace[Workspace path]:path:_files -/' \
                                        '--format[Output format]:format:(json markdown)'
                                    ;;
                                import)
                                    _arguments \
                                        '1:json file:_files -g "*.json"' \
                                        '--dry-run[Preview import without executing]'
                                    ;;
                                convert)
                                    _arguments \
                                        '1:session path:_files' \
                                        '--from[Source agent]:agent:(claude-code codex gemini)' \
                                        '--to[Target agent]:agent:(claude-code codex gemini)' \
                                        '--workspace[Workspace path]:path:_files -/' \
                                        '--session-id[Target session id]:session id:' \
                                        '--dry-run[Preview conversion without writing output]' \
                                        '--json[Output JSON summary]' \
                                        '--no-json[Output plain-text summary]'
                                    ;;
                                show)
                                    _arguments \
                                        '1:session id:' \
                                        '--format[Output format]:format:(json markdown summary)'
                                    ;;
                                list-imported)
                                    _arguments
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                dashboard|dash)
                    _arguments -C \
                        '1: :_acfs_dashboard_commands' \
                        '*::arg:->dashboard_args'
                    ;;
                update|continue|progress|services-setup|services|setup|support-bundle|bundle)
                    _arguments \
                        '-h[Show help message]' \
                        '--help[Show help message]'
                    ;;
            esac
            ;;
    esac
}

_acfs_commands() {
    local commands
    commands=(
        'newproj:Create new project (git, br, AGENTS.md, Claude settings)'
        'new:Create new project (alias for newproj)'
        'services-setup:Configure AI agents and cloud services'
        'services:Configure services (alias for services-setup)'
        'setup:Configure services (alias for services-setup)'
        'doctor:Check system health and tool status'
        'check:Check system health (alias for doctor)'
        'session:List/export/import agent sessions (cass)'
        'sessions:Agent sessions (alias for session)'
        'update:Update ACFS tools to latest versions'
        'status:Quick one-line health summary (fast, no network)'
        'continue:View installation progress (after Ubuntu upgrade)'
        'progress:View progress (alias for continue)'
        'info:Quick system overview (hostname, IP, uptime, progress)'
        'i:System overview (alias for info)'
        'capacity:Estimate safe/recommended agent counts'
        'cap:Capacity report (alias for capacity)'
        'policy-lint:Lint AGENTS/templates/docs for policy drift'
        'policy_lint:Lint AGENTS/templates/docs for policy drift'
        'credential-preflight:Read-only credential exposure preflight'
        'credential_preflight:Read-only credential exposure preflight'
        'secrets-preflight:Alias for credential-preflight'
        'secrets_preflight:Alias for credential-preflight'
        'swarm:Swarm plan, status, doctor, simulation, packets, and inventory'
        'swarm-plan:Queue-aware launch advisor'
        'swarm_plan:Queue-aware launch advisor'
        'swarm-status:Local swarm status snapshot'
        'swarm_status:Local swarm status snapshot'
        'swarm-simulate:Dry-run fleet-scale simulation harness'
        'swarm_simulate:Dry-run fleet-scale simulation harness'
        'swarm-packet:Per-agent startup packet generator'
        'swarm_packet:Per-agent startup packet generator'
        'swarm-assign:Role-aware Beads assignment planner'
        'swarm_assign:Role-aware Beads assignment planner'
        'swarm-convergence:Epic success-criteria convergence audit'
        'swarm_convergence:Epic success-criteria convergence audit'
        'swarm-calibration:Artifact-backed capacity calibration report'
        'swarm_calibration:Artifact-backed capacity calibration report'
        'swarm-inventory:Local host inventory report/import/export/validate'
        'swarm_inventory:Local host inventory report/import/export/validate'
        'provisioning-packet:Validate/render provider provisioning packet JSON'
        'provider-packet:Validate/render provider packet JSON'
        'offline-pack:Build verified offline artifact packs'
        'artifact-pack:Build verified offline artifact packs'
        'coordinate:Coordination preflight helpers'
        'coord:Coordination helpers (alias for coordinate)'
        'cheatsheet:Command reference (aliases, shortcuts)'
        'cs:Command reference (alias for cheatsheet)'
        'changelog:Show recent project changes'
        'changes:Show recent project changes (alias for changelog)'
        'log:Show recent project changes (alias for changelog)'
        'export-config:Export config for backup or migration'
        'export:Export config (alias for export-config)'
        'dashboard:Static HTML dashboard'
        'dash:Dashboard (alias for dashboard)'
        'support-bundle:Collect diagnostic data for troubleshooting'
        'bundle:Support bundle (alias for support-bundle)'
        'version:Show ACFS version'
        'help:Show help message'
    )
    _describe -t commands 'acfs command' commands
}

_acfs_session_commands() {
    local commands
    commands=(
        'list:List sessions'
        'export:Export a session'
        'recent:Show recent sessions'
        'import:Import a session'
        'convert:Convert a native session between agent formats'
        'show:Show session details'
        'list-imported:List locally imported session exports'
    )
    _describe -t commands 'session command' commands
}

_acfs_dashboard_commands() {
    local commands
    commands=(
        'generate:Generate static HTML dashboard'
        'serve:Serve dashboard locally'
    )
    _describe -t commands 'dashboard command' commands
}

_acfs_swarm_commands() {
    local commands
    commands=(
        'plan:Queue-aware launch advisor'
        'advisor:Queue-aware launch advisor'
        'status:Local coordination snapshot'
        'snapshot:Local coordination snapshot'
        'doctor:Pre-swarm coordination preflight'
        'preflight:Pre-swarm coordination preflight'
        'simulate:Dry-run fleet-scale simulation harness'
        'packet:Per-agent startup packet generator'
        'assign:Role-aware Beads assignment planner'
        'convergence:Epic success-criteria convergence audit'
        'calibration:Artifact-backed capacity calibration report'
        'inventory:Local host inventory report/import/export/validate'
        'hosts:Local host inventory report/import/export/validate'
        'host-inventory:Local host inventory report/import/export/validate'
        'help:Show swarm help'
    )
    _describe -t commands 'swarm command' commands
}

_acfs_coordinate_commands() {
    local commands
    commands=(
        'doctor:Pre-swarm coordination preflight'
        'preflight:Pre-swarm coordination preflight'
        'help:Show coordinate help'
    )
    _describe -t commands 'coordinate command' commands
}

_acfs "$@"
